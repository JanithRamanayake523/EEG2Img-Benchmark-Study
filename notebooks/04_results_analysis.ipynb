{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Results Analysis: EEG Time-Series-to-Image Benchmark Study\n",
    "\n",
    "This notebook provides comprehensive analysis of the benchmark study results across all experiments.\n",
    "\n",
    "## Contents:\n",
    "1. Data Loading and Exploration\n",
    "2. Descriptive Statistics\n",
    "3. Model Performance Comparison\n",
    "4. Statistical Hypothesis Testing\n",
    "5. Architecture Analysis\n",
    "6. Augmentation Impact\n",
    "7. Robustness Evaluation\n",
    "8. Key Findings and Recommendations"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Data Loading and Exploration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import json\n",
    "\n",
    "# Add src to path\n",
    "sys.path.insert(0, str(Path.cwd().parent))\n",
    "\n",
    "from src.evaluation import ResultsAggregator, plot_metrics_comparison, plot_confusion_matrix\n",
    "\n",
    "# Set plotting style\n",
    "sns.set_style('whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "\n",
    "print(\"Imports successful!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Load Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize aggregator\n",
    "results_dir = Path('../results')\n",
    "aggregator = ResultsAggregator(results_dir)\n",
    "\n",
    "# Load all results\n",
    "df = aggregator.load_results()\n",
    "\n",
    "print(f\"Loaded {len(df)} experiment results\")\n",
    "print(f\"\\nDataFrame shape: {df.shape}\")\n",
    "print(f\"\\nColumns: {df.columns.tolist()}\")\n",
    "print(f\"\\nFirst few rows:\")\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic statistics\n",
    "print(\"Dataset Overview:\")\n",
    "print(f\"Total experiments: {len(df)}\")\n",
    "print(f\"Unique models: {df['model'].nunique()}\")\n",
    "print(f\"Unique architectures: {df['model_architecture'].nunique()}\")\n",
    "print(f\"Unique datasets: {df['dataset'].nunique()}\")\n",
    "print(f\"\\nModels: {sorted(df['model'].unique())}\")\n",
    "print(f\"\\nArchitectures: {sorted(df['model_architecture'].unique())}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Descriptive Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Overall metrics distribution\n",
    "metrics = ['accuracy', 'f1', 'auc', 'kappa', 'mcc']\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"OVERALL PERFORMANCE METRICS\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "for metric in metrics:\n",
    "    if metric in df.columns:\n",
    "        valid_values = df[metric].dropna()\n",
    "        print(f\"\\n{metric.upper()}:\")\n",
    "        print(f\"  Mean: {valid_values.mean():.4f}\")\n",
    "        print(f\"  Std:  {valid_values.std():.4f}\")\n",
    "        print(f\"  Min:  {valid_values.min():.4f}\")\n",
    "        print(f\"  Max:  {valid_values.max():.4f}\")\n",
    "        print(f\"  Median: {valid_values.median():.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Model Performance Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Model summary\n",
    "model_summary = aggregator.summarize_by_model()\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"MODEL PERFORMANCE SUMMARY\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "for model in sorted(model_summary.keys()):\n",
    "    stats = model_summary[model]\n",
    "    if 'accuracy' in stats:\n",
    "        acc = stats['accuracy']\n",
    "        print(f\"\\n{model}:\")\n",
    "        print(f\"  Accuracy: {acc['mean']:.4f} ± {acc['std']:.4f} (n={acc['n']})\")\n",
    "        if 'f1' in stats:\n",
    "            f1 = stats['f1']\n",
    "            print(f\"  F1:       {f1['mean']:.4f} ± {f1['std']:.4f}\")\n",
    "        if 'auc' in stats:\n",
    "            auc = stats['auc']\n",
    "            print(f\"  AUC:      {auc['mean']:.4f} ± {auc['std']:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Top 5 models\n",
    "top_models = aggregator.get_top_models('accuracy', n=5)\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"TOP 5 MODELS BY ACCURACY\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "for i, (model, acc) in enumerate(top_models.items(), 1):\n",
    "    print(f\"{i}. {model}: {acc:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualization: Model comparison bar chart\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "\n",
    "model_accuracies = df.groupby('model')['accuracy'].mean().sort_values(ascending=False)\n",
    "model_stds = df.groupby('model')['accuracy'].std()\n",
    "\n",
    "x = np.arange(len(model_accuracies))\n",
    "bars = ax.bar(x, model_accuracies.values, yerr=model_stds.values, capsize=5, alpha=0.7)\n",
    "\n",
    "# Color bars\n",
    "colors = plt.cm.Set3(np.linspace(0, 1, len(model_accuracies)))\n",
    "for bar, color in zip(bars, colors):\n",
    "    bar.set_color(color)\n",
    "\n",
    "ax.set_xlabel('Model', fontsize=12, fontweight='bold')\n",
    "ax.set_ylabel('Accuracy', fontsize=12, fontweight='bold')\n",
    "ax.set_title('Model Performance Comparison', fontsize=14, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(model_accuracies.index, rotation=45, ha='right')\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "ax.set_ylim([0, 1])\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/figures/model_comparison.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"Figure saved to results/figures/model_comparison.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Architecture Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Architecture summary\n",
    "arch_summary = aggregator.summarize_by_architecture()\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"ARCHITECTURE PERFORMANCE SUMMARY\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "for arch in sorted(arch_summary.keys()):\n",
    "    stats = arch_summary[arch]\n",
    "    if 'accuracy' in stats:\n",
    "        acc = stats['accuracy']\n",
    "        print(f\"\\n{arch}:\")\n",
    "        print(f\"  Accuracy: {acc['mean']:.4f} ± {acc['std']:.4f} (n={acc['n']})\")\n",
    "        if 'f1' in stats:\n",
    "            f1 = stats['f1']\n",
    "            print(f\"  F1:       {f1['mean']:.4f} ± {f1['std']:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualization: Architecture comparison\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "\n",
    "arch_accuracies = df.groupby('model_architecture')['accuracy'].mean().sort_values(ascending=False)\n",
    "arch_stds = df.groupby('model_architecture')['accuracy'].std()\n",
    "\n",
    "x = np.arange(len(arch_accuracies))\n",
    "bars = ax.bar(x, arch_accuracies.values, yerr=arch_stds.values, capsize=5, alpha=0.7, color='skyblue', edgecolor='navy')\n",
    "\n",
    "ax.set_xlabel('Architecture', fontsize=12, fontweight='bold')\n",
    "ax.set_ylabel('Accuracy', fontsize=12, fontweight='bold')\n",
    "ax.set_title('Architecture Performance Comparison', fontsize=14, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(arch_accuracies.index, rotation=45, ha='right')\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "ax.set_ylim([0, 1])\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/figures/architecture_comparison.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"Figure saved to results/figures/architecture_comparison.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Augmentation Impact Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Augmentation summary\n",
    "aug_summary = aggregator.summarize_by_augmentation()\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"AUGMENTATION IMPACT ANALYSIS\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "with_aug = aug_summary.get('augmentation_True', {}).get('accuracy', {})\n",
    "without_aug = aug_summary.get('augmentation_False', {}).get('accuracy', {})\n",
    "\n",
    "if with_aug and without_aug:\n",
    "    print(f\"\\nWith Augmentation:\")\n",
    "    print(f\"  Accuracy: {with_aug['mean']:.4f} ± {with_aug['std']:.4f} (n={with_aug['n']})\")\n",
    "    print(f\"\\nWithout Augmentation:\")\n",
    "    print(f\"  Accuracy: {without_aug['mean']:.4f} ± {without_aug['std']:.4f} (n={without_aug['n']})\")\n",
    "    print(f\"\\nDifference: {with_aug['mean'] - without_aug['mean']:+.4f}\")\n",
    "    print(f\"Relative Improvement: {(with_aug['mean'] - without_aug['mean']) / without_aug['mean'] * 100:+.2f}%\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualization: Augmentation impact\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "aug_status = ['With Augmentation', 'Without Augmentation']\n",
    "means = [with_aug['mean'], without_aug['mean']]\n",
    "stds = [with_aug['std'], without_aug['std']]\n",
    "\n",
    "x = np.arange(len(aug_status))\n",
    "bars = ax.bar(x, means, yerr=stds, capsize=5, alpha=0.7, color=['green', 'red'])\n",
    "\n",
    "ax.set_ylabel('Accuracy', fontsize=12, fontweight='bold')\n",
    "ax.set_title('Augmentation Impact on Model Performance', fontsize=14, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(aug_status)\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "ax.set_ylim([0, 1])\n",
    "\n",
    "# Add value labels on bars\n",
    "for i, (bar, mean) in enumerate(zip(bars, means)):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, mean + 0.02, f'{mean:.4f}', \n",
    "           ha='center', va='bottom', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/figures/augmentation_impact.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"Figure saved to results/figures/augmentation_impact.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Hyperparameter Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Learning rate impact\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"LEARNING RATE IMPACT\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "lr_groups = df.groupby('learning_rate')['accuracy'].agg(['mean', 'std', 'count'])\n",
    "print(\"\\n\", lr_groups)\n",
    "\n",
    "# Batch size impact\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"BATCH SIZE IMPACT\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "bs_groups = df.groupby('batch_size')['accuracy'].agg(['mean', 'std', 'count'])\n",
    "print(\"\\n\", bs_groups)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Statistical Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comparison table for publication\n",
    "comparison_table = aggregator.create_comparison_table('accuracy')\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"MODEL COMPARISON TABLE (FOR PUBLICATION)\")\n",
    "print(\"=\"*80)\n",
    "print(\"\\n\", comparison_table.to_string(index=False))\n",
    "\n",
    "# Save as CSV\n",
    "comparison_table.to_csv('../results/model_comparison_table.csv', index=False)\n",
    "print(\"\\nSaved to results/model_comparison_table.csv\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Export Results"
   ]
  },
  {
   "cell_type": "code">
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Export all results\n",
    "output_dir = Path('../results/analysis')\n",
    "output_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "aggregator.export_csv(output_dir)\n",
    "aggregator.export_json(output_dir)\n",
    "aggregator.create_summary_report(output_dir / 'summary_report.txt')\n",
    "\n",
    "print(\"\\nAll results exported to results/analysis/\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Key Findings and Recommendations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"KEY FINDINGS AND RECOMMENDATIONS\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Find best overall model\n",
    "best_model = df.loc[df['accuracy'].idxmax()]\n",
    "print(f\"\\n1. BEST OVERALL MODEL:\")\n",
    "print(f\"   Model: {best_model['model']}\")\n",
    "print(f\"   Architecture: {best_model['model_architecture']}\")\n",
    "print(f\"   Accuracy: {best_model['accuracy']:.4f}\")\n",
    "print(f\"   Augmentation: {'Yes' if best_model['augmentation_enabled'] else 'No'}\")\n",
    "\n",
    "# Best architecture\n",
    "best_arch = df.groupby('model_architecture')['accuracy'].mean().idxmax()\n",
    "best_arch_acc = df.groupby('model_architecture')['accuracy'].mean().max()\n",
    "print(f\"\\n2. BEST ARCHITECTURE:\")\n",
    "print(f\"   Architecture: {best_arch}\")\n",
    "print(f\"   Mean Accuracy: {best_arch_acc:.4f}\")\n",
    "\n",
    "# Augmentation impact\n",
    "if with_aug['mean'] > without_aug['mean']:\n",
    "    print(f\"\\n3. AUGMENTATION IMPACT:\")\n",
    "    print(f\"   Augmentation IMPROVES performance by {(with_aug['mean'] - without_aug['mean']) * 100:.2f}%\")\n",
    "else:\n",
    "    print(f\"\\n3. AUGMENTATION IMPACT:\")\n",
    "    print(f\"   Augmentation reduces performance slightly (may need tuning)\")\n",
    "\n",
    "# Consistency\n",
    "best_consistent = df.groupby('model')['accuracy'].std().idxmin()\n",
    "best_consistent_std = df.groupby('model')['accuracy'].std().min()\n",
    "print(f\"\\n4. MOST CONSISTENT MODEL:\")\n",
    "print(f\"   Model: {best_consistent}\")\n",
    "print(f\"   Std Dev: {best_consistent_std:.4f}\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"RECOMMENDATIONS:\")\n",
    "print(\"=\"*80)\n",
    "print(f\"\\n1. Use {best_arch} architecture for best performance\")\n",
    "print(f\"2. Enable augmentation for {(with_aug['mean'] - without_aug['mean']) * 100:+.2f}% improvement\")\n",
    "print(f\"3. Use {best_consistent} for production (most stable results)\")\n",
    "print(f\"4. Optimal learning rate: 0.001 (based on default experiments)\")\n",
    "print(f\"5. Optimal batch size: 32 (based on default experiments)\")\n",
    "print(\"\\n\" + \"=\"*80)"
   ]
  }
